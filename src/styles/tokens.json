{
  "$schema": "design-tokens-v1",
  "_doc": "BookmarkBrain — single locked theme: echo-sage + liquid glass + Onest/Lora. Source of truth is colors_and_type.css.",

  "fonts": {
    "ui":      "Onest, -apple-system, system-ui, sans-serif",
    "display": "Lora, Georgia, serif",
    "mono":    "JetBrains Mono, ui-monospace, monospace"
  },

  "color": {
    "brand": {
      "primary":      "#7A9C7A",
      "primaryHover": "#688A68",
      "primaryPress": "#547654",
      "primaryTint":  "#E2EDE2"
    },
    "surface": {
      "page":     "#F5F1EB",
      "card":     "#FAF7F1",
      "elevated": "#FFFCF6",
      "sunken":   "#EAE3CF"
    },
    "text": {
      "fg1": "#2C2825",
      "fg2": "#6B645B",
      "fg3": "#9A938A",
      "fg4": "#C5BFB4",
      "onBrand": "#FFFFFF"
    },
    "border": {
      "hairline":  "#E8E1D2",
      "card":      "#D8CFBC",
      "strong":    "#BDB29A",
      "glassEdge": "rgba(255,255,255,0.6)"
    },
    "ai": {
      "suggestBg":     "#ECF2EC",
      "suggestBorder": "#CFDFCF",
      "suggestFg":     "#2F4A2F",
      "processing":    "#7A9C7A"
    },
    "semantic": {
      "success": "#5A8A56",
      "warn":    "#C49454",
      "error":   "#B5483A",
      "info":    "#5A7A8A"
    },
    "tags": {
      "sage":  "#7A9C7A",
      "ochre": "#C18840",
      "slate": "#4F6A7A",
      "plum":  "#8A5C8C",
      "clay":  "#B5483A",
      "moss":  "#6B7A3F",
      "rose":  "#C84B5A",
      "taupe": "#8E908A"
    },
    "tagSurfaces": {
      "sage":  { "bg": "#E2EDE2", "fg": "#2F4A2F" },
      "ochre": { "bg": "#F4E6CC", "fg": "#7A5828" },
      "slate": { "bg": "#D8E2EA", "fg": "#3D5A6E" },
      "plum":  { "bg": "#E5D8E8", "fg": "#5C3D6E" },
      "clay":  { "bg": "#EFD8D2", "fg": "#8A2A20" },
      "moss":  { "bg": "#E0E5C8", "fg": "#4A5A2A" },
      "rose":  { "bg": "#F4D8DC", "fg": "#8A2A35" },
      "taupe": { "bg": "#E0DED8", "fg": "#56544C" }
    }
  },

  "brandLight": {
    "_doc": "Signature backdrop gradient — always layered as light source. Page bg, hero blocks, modal backdrops.",
    "tints": {
      "sage":    "rgba(218,234,218,0.55)",
      "apricot": "rgba(252,220,194,0.55)",
      "blush":   "rgba(248,226,218,0.45)"
    },
    "base": { "top": "#F5F1EB", "bottom": "#F0EBE2" },
    "css": "radial-gradient(80% 60% at 12% 0%, rgba(218,234,218,0.55) 0%, transparent 60%), radial-gradient(70% 60% at 100% 12%, rgba(252,220,194,0.55) 0%, transparent 55%), radial-gradient(60% 50% at 60% 100%, rgba(248,226,218,0.45) 0%, transparent 60%), linear-gradient(180deg, #F5F1EB 0%, #F0EBE2 100%)"
  },

  "spacing": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64 },

  "radius": { "xs": 6, "sm": 10, "md": 16, "lg": 22, "xl": 28, "2xl": 36, "pill": 999 },

  "fontSize": { "10": 10, "11": 11, "12": 12, "13": 13, "14": 14, "15": 15, "16": 16, "18": 18, "20": 20, "22": 22, "24": 24, "28": 28, "32": 32, "36": 36, "44": 44, "56": 56 },

  "lineHeight": { "tight": 1.02, "snug": 1.15, "normal": 1.4, "body": 1.5, "loose": 1.6 },

  "letterSpacing": {
    "displayTight": "-0.04em",
    "headingTight": "-0.035em",
    "h1": "-0.025em",
    "h2": "-0.02em",
    "body": "-0.005em",
    "caps": "0.12em",
    "mono": "0.06em"
  },

  "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },

  "shadow": {
    "1":     "0 1px 2px rgba(60,40,25,0.04), 0 1px 1px rgba(60,40,25,0.03)",
    "2":     "0 4px 14px rgba(60,40,25,0.05), 0 1px 3px rgba(60,40,25,0.04)",
    "3":     "0 14px 40px rgba(60,40,25,0.08), 0 4px 10px rgba(60,40,25,0.04)",
    "pop":   "0 24px 60px rgba(60,40,25,0.14), 0 8px 20px rgba(60,40,25,0.06)",
    "glass": "0 1px 0 rgba(255,255,255,0.6) inset, 0 -1px 0 rgba(0,0,0,0.04) inset, 0 10px 30px rgba(60,40,25,0.08)",
    "insetHighlight": "inset 0 1px 0 rgba(255,255,255,0.5)"
  },

  "glass": {
    "_doc": "Liquid glass primitives. Apply as: bg=tint + backdrop-filter(blur+saturate) + border(glassEdge) + shadow.glass.",
    "blur":       "20px",
    "blurStrong": "32px",
    "tintLight":  "rgba(255,252,246,0.55)",
    "tintMedium": "rgba(255,252,246,0.35)",
    "tintStrong": "rgba(255,252,246,0.72)",
    "saturate":   "140%",
    "saturateStrong": "160%"
  },

  "motion": {
    "ease": {
      "out":   "cubic-bezier(0.2,0.8,0.2,1)",
      "inOut": "cubic-bezier(0.4,0,0.2,1)"
    },
    "dur": { "fast": 120, "base": 200, "slow": 320 }
  }
}
